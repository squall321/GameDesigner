# Unreal Engine generated / build artifacts — never commit these.
# https://github.com/Epic-Games conventions.

# Build output
Binaries/
DerivedDataCache/
Intermediate/
Saved/
Build/

# Plugin-local build output (the plugin can live at repo root or under a project's Plugins/)
Plugins/**/Binaries/
Plugins/**/Intermediate/

# Project files generated by "Generate Project Files"
*.sln
*.suo
*.opensdf
*.sdf
*.VC.db
*.VC.opendb
.vs/
*.xcodeproj/
*.xcworkspace/

# IDE / editor
.idea/
.vscode/
*.code-workspace

# OS clutter
.DS_Store
Thumbs.db
desktop.ini

# Crash / log dumps
*.log
*.dmp

# Python checker cache
__pycache__/
*.pyc

# Compiled binaries that may slip in
*.obj
*.pdb
*.exp
*.lib
*.dll
*.so
*.dylib

# Claude Code session/harness state — not project content
.claude/
